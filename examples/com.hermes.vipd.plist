<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hermes.vipd</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/hermes-vipd</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>UserName</key>
    <string>root</string>

    <key>StandardOutPath</key>
    <string>/var/log/hermes-vip/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/var/log/hermes-vip/stderr.log</string>
</dict>
</plist>
